# ==============================================================================
# SUPASTARTER NEXT.JS - ENVIRONMENT VARIABLES CONFIGURATION
# ==============================================================================
# This is the EXACT SAME Supastarter kit from: https://github.com/finnash/finstarter-nextjs-main
# 
# REQUIRED VARIABLES (Must be configured):
# ==============================================================================

# 1. DATABASE CONFIGURATION (REQUIRED)
# -------------------------------------
# You need a PostgreSQL database. Recommended providers:
# - Neon.tech (Free tier): https://neon.tech
# - Supabase: https://supabase.com
# - Railway: https://railway.app
# - PlanetScale: https://planetscale.com
DATABASE_URL="postgresql://username:password@hostname:5432/database_name"
DIRECT_URL="postgresql://username:password@hostname:5432/database_name"

# 2. AUTHENTICATION SECRET (REQUIRED)
# -----------------------------------
# Generate a random secret key (use: openssl rand -base64 32)
BETTER_AUTH_SECRET="your-secret-key-here-change-this-to-a-secure-random-string"

# 3. APPLICATION URL (REQUIRED)
# -----------------------------
# Your app's public URL (change after deployment)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SAAS_ENABLED="true"

# 4. EMAIL SERVICE CONFIGURATION (REQUIRED for auth)
# --------------------------------------------------
# For Gmail (Development):
# 1. Enable 2FA on your Gmail account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use App Password as SMTP_PASSWORD
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587" 
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-gmail-app-password"
SMTP_FROM="noreply@yourdomain.com"

# For Production (SendGrid, Mailgun, etc.):
# SMTP_HOST="smtp.sendgrid.net"
# SMTP_PORT="587"
# SMTP_USER="apikey"
# SMTP_PASSWORD="your-sendgrid-api-key"

# ==============================================================================
# OPTIONAL VARIABLES (Enable features):
# ==============================================================================

# 5. SOCIAL LOGIN PROVIDERS (Optional but recommended)
# ---------------------------------------------------

# Google OAuth (Get from: https://console.cloud.google.com):
# 1. Create new project or select existing
# 2. Enable Google+ API
# 3. Create OAuth 2.0 credentials
# 4. Add your domain to authorized origins
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth (Get from: https://github.com/settings/developers):
# 1. Go to Settings > Developer settings > OAuth Apps
# 2. Create new OAuth App
# 3. Set Authorization callback URL to: https://yourdomain.com/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# 6. PAYMENT PROCESSING (Optional - for SaaS billing)
# --------------------------------------------------
# Stripe (Get from: https://dashboard.stripe.com/apikeys):
STRIPE_PUBLIC_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Stripe Product IDs (Create products in Stripe dashboard):
NEXT_PUBLIC_PRICE_ID_PRO_MONTHLY=""
NEXT_PUBLIC_PRICE_ID_PRO_YEARLY=""
NEXT_PUBLIC_PRICE_ID_LIFETIME=""

# 7. FILE STORAGE (Optional - for file uploads)
# --------------------------------------------
# AWS S3 or compatible service:
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET_NAME=""
NEXT_PUBLIC_AVATARS_BUCKET_NAME="avatars"

# Alternative: Cloudflare R2, DigitalOcean Spaces, etc.

# 8. AI SERVICES (Optional - for AI chat feature)
# ----------------------------------------------
# OpenAI API:
OPENAI_API_KEY=""

# Alternative AI providers:
# ANTHROPIC_API_KEY=""
# GOOGLE_AI_API_KEY=""

# 9. ANALYTICS & MONITORING (Optional)
# -----------------------------------
# Vercel Analytics:
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=""

# Sentry (Error monitoring):
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# 10. DEVELOPMENT SETTINGS
# ------------------------
NODE_ENV="development"

# ==============================================================================
# DEPLOYMENT PLATFORM SPECIFIC:
# ==============================================================================

# Vercel deployment:
# - Add all above variables to Vercel dashboard
# - Variables > Environment Variables

# Railway deployment:
# - Add variables in Railway dashboard
# - Settings > Environment

# DigitalOcean App Platform:
# - Add variables in App Platform console
# - Settings > Environment Variables

# ==============================================================================
# SETUP INSTRUCTIONS:
# ==============================================================================
# 1. Copy this file to `.env` (remove .example)
# 2. Fill in the REQUIRED variables above
# 3. Add optional variables as needed for features
# 4. Never commit .env file to git (already in .gitignore)
# 5. Add all variables to your deployment platform
# ==============================================================================